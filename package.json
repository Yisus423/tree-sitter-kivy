{
  "name": "tree-sitter-kivy",
  "version": "0.1.3",
  "description": "Kivy KV language grammar for tree-sitter",
  "repository": "https://github.com/tree-sitter/tree-sitter-kivy",
  "license": "MIT",
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "kivy",
    "kvlang"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "dependencies": {
    "node-addon-api": "^8.2.2",
    "node-gyp-build": "^4.8.2"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.26.10",
    "prebuildify": "^6.0.1"
  },
  "peerDependencies": {
    "tree-sitter": "^0.21.1"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "test": "tree-sitter test",
    "test:e2e": "node test/e2e/verify.mjs",
    "build:wasm": "tree-sitter build --wasm",
    "playground": "tree-sitter playground"
  }
}
