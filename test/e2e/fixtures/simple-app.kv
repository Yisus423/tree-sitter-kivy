#:kivy 2.0
#:import FloatLayout kivy.uix.floatlayout
#:set default_bg (0.9, 0.9, 0.9, 1)

<CustomButton@Button>:
    font_size: 16
    size_hint: (0.3, 0.1)

<MainScreen>:
    # Main container with background
    canvas.before:
        Color:
            rgba: (0.95, 0.95, 0.95, 1)
        Rectangle:
            size: self.size
            pos: (0, 0)

    FloatLayout:
        Label:
            id: title_label
            text: "Welcome to Kivy"
            font_size: 24
            bold: True
            color: (0.2, 0.2, 0.2, 1)
            size_hint: (0.8, 0.2)
            pos_hint: {'center_x': 0.5, 'center_y': 0.9}

        CustomButton:
            text: "Click Me"
            on_press: app.handle_click()
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
